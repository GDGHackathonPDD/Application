# Copy to `.env.local` and fill in. Never commit `.env.local`.

# Clerk — Frontend API URL must match Application/convex/auth.config.ts `providers[0].domain`
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex — after `npx convex dev` (deployment URL + site URL from dashboard)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Agent API (`npm run agent-api`) — Convex dashboard must also set AGENT_API_URL + AGENT_API_KEY for actions
AGENT_API_URL=http://127.0.0.1:8000
AGENT_API_KEY=

# OpenRouter — local Agent API only (never use NEXT_PUBLIC_ for this)
OPENROUTER_API_KEY=
# Optional OpenRouter attribution
# OPENROUTER_SITE_URL=
# OPENROUTER_SITE_NAME=

RESEND_API_KEY=
