# Clerk — also create JWT template named "convex" (Dashboard → JWT Templates → New → Convex).
# Required for Convex + Clerk and for server routes that call Convex (e.g. Google Calendar callback).
# https://docs.convex.dev/auth/clerk
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Site URL for OAuth redirects (no trailing slash), e.g. http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Google Calendar API (OAuth) — create OAuth client in Google Cloud Console; add authorized redirect:
#   {NEXT_PUBLIC_APP_URL}/api/google-calendar/callback
# Copy client id/secret here for Next.js. Mirror id + secret + encryption key in Convex dashboard for `googleCalendarSync` action.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Base64 32-byte key: openssl rand -base64 32 — set the same value in Convex env as GOOGLE_OAUTH_ENCRYPTION_KEY
GOOGLE_OAUTH_ENCRYPTION_KEY=

# Convex — after `npx convex dev` (see .agents/CONVEX_MIGRATION_PLAN.md Phase A)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Agent API (`npm run agent-api`). Convex actions read env from the Convex dashboard (or `npx convex env set`), not from this file — mirror AGENT_* there for LLM decomposition.
AGENT_API_URL=http://127.0.0.1:8000
AGENT_API_KEY=

# OpenRouter — local Agent API only (never use NEXT_PUBLIC_ for this)
OPENROUTER_API_KEY=
# Optional OpenRouter attribution
# OPENROUTER_SITE_URL=
# OPENROUTER_SITE_NAME=

RESEND_API_KEY=
